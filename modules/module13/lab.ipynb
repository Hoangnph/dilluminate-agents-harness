    "# 🏗️ Module 13 Lab — Agent Orchestration Patterns & Advanced Architectures\n",
    "\n",
    "**Mục tiêu:** Implement Fan-Out/Fan-In, Map-Reduce, Saga, và Dynamic Router cho LoanBot v3.1\n",
    "\n",
    "Trong lab này, bạn sẽ xây dựng:\n",
    "1. `FanOutOrchestrator` — parallel agent execution với asyncio\n",
    "2. `MapReducePipeline` — batch processing 50.000 hồ sơ với PortfolioReducer\n",
    "3. `SagaOrchestrator` — distributed transactions với compensating actions\n",
    "4. `DynamicRouter` — runtime path selection dựa trên complexity_score\n",
    "5. `LoanBotV31` — tích hợp tất cả patterns vào production architecture"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 1: Setup và Mock Agents"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import asyncio\n",
    "import hashlib\n",
    "import statistics\n",
    "import time\n",
    "import random\n",
    "from dataclasses import dataclass, field\n",
    "from typing import List, Dict, Any, Optional, Callable, Tuple\n",
    "from enum import Enum\n",
    "\n",
    "print('✅ Imports OK')\n",
    "\n",
    "# ─────── 4 LoanBot customers ───────\n",
    "CUSTOMERS = {\n",
    "    'FC-2024-001': {'name': 'Nguyễn Văn A', 'credit_score': 720, 'loan_amount_vnd': 200_000_000,\n",
    "                    'monthly_income_vnd': 25_000_000, 'fraud_probability': 0.05,\n",
    "                    'regulatory_flag': False, 'employment_months': 48},\n",
    "    'FC-2024-002': {'name': 'Trần Thị B',   'credit_score': 580, 'loan_amount_vnd': 150_000_000,\n",
    "                    'monthly_income_vnd': 12_000_000, 'fraud_probability': 0.18,\n",
    "                    'regulatory_flag': False, 'employment_months': 18},\n",
    "    'FC-2024-003': {'name': 'Lê Văn C',     'credit_score': 400, 'loan_amount_vnd': 80_000_000,\n",
    "                    'monthly_income_vnd': 8_000_000,  'fraud_probability': 0.72,\n",
    "                    'regulatory_flag': False, 'employment_months': 6},\n",
    "    'FC-2024-004': {'name': 'Phạm Thị D',   'credit_score': 645, 'loan_amount_vnd': 450_000_000,\n",
    "                    'monthly_income_vnd': 30_000_000, 'fraud_probability': 0.28,\n",
    "                    'regulatory_flag': True, 'employment_months': 36},\n",
    "}\n",
    "\n",
    "# ─────── Mock agent functions (simulate LLM calls with latency) ───────\n",
    "async def mock_credit_agent(data: Dict) -> Dict:\n",
    "    await asyncio.sleep(0.1)  # simulated latency\n",
    "    score = data['credit_score']\n",
    "    dti = data['loan_amount_vnd'] / (data['monthly_income_vnd'] * 12)\n",
    "    return {\n",
    "        'credit_score': score, 'dti': round(dti, 2),\n",
    "        'credit_grade': 'A' if score >= 720 else 'B' if score >= 620 else 'C' if score >= 560 else 'D',\n",
    "        'history_clean': score > 500\n",
    "    }\n",
    "\n",
    "async def mock_income_agent(data: Dict) -> Dict:\n",
    "    await asyncio.sleep(0.09)\n",
    "    income = data['monthly_income_vnd']\n",
    "    stable = data['employment_months'] >= 12\n",
    "    return {\n",
    "        'verified_monthly_income_vnd': income,\n",
    "        'employment_stable': stable,\n",
    "        'income_grade': 'SUFFICIENT' if income >= 15_000_000 else 'MARGINAL' if income >= 8_000_000 else 'INSUFFICIENT'\n",
    "    }\n",
    "\n",
    "async def mock_fraud_agent(data: Dict) -> Dict:\n",
    "    await asyncio.sleep(0.11)\n",
    "    fp = data['fraud_probability']\n",
    "    return {\n",
    "        'fraud_probability': fp,\n",
    "        'fraud_tier': 'HIGH' if fp > 0.50 else 'MEDIUM' if fp > 0.20 else 'LOW',\n",
    "        'pep_match': False,\n",
    "        'blacklist_match': fp > 0.70\n",
    "    }\n",
    "\n",
    "async def mock_risk_agent(data: Dict, credit_r: Dict, income_r: Dict, fraud_r: Dict) -> Dict:\n",
    "    await asyncio.sleep(0.08)\n",
    "    score = credit_r['credit_score']\n",
    "    fp = fraud_r['fraud_probability']\n",
    "    risk_score = round((1 - score/850) * 0.5 + fp * 0.5, 3)\n",
    "    if fraud_r['blacklist_match'] or score < 450:\n",
    "        decision = 'REJECT'\n",
    "    elif risk_score < 0.35 and income_r['income_grade'] != 'INSUFFICIENT':\n",
    "        decision = 'APPROVE'\n",
    "    else:\n",
    "        decision = 'REVIEW'\n",
    "    return {'risk_score': risk_score, 'decision': decision}\n",
    "\n",
    "print('✅ Mock agents defined')"
   ]
