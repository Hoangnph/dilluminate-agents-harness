    "class LoanBotV31:\n",
    "    \"\"\"LoanBot v3.1 — integrates Dynamic Routing + Fan-Out/Fan-In + Saga.\"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.router = DynamicRouter()\n",
    "        self.orch   = FanOutOrchestrator(max_concurrent=20)\n",
    "        self.processed: List[Dict] = []\n",
    "\n",
    "    async def _fast_path(self, loan_id: str, data: Dict) -> Dict:\n",
    "        credit = await mock_credit_agent(data)\n",
    "        if credit['credit_score'] >= 700 and credit['dti'] < 0.5:\n",
    "            return {'decision': 'APPROVE', 'path': 'FAST', 'credit': credit}\n",
    "        return {'decision': 'REVIEW', 'path': 'FAST', 'credit': credit}\n",
    "\n",
    "    async def process(self, loan_id: str, data: Dict) -> Dict:\n",
    "        route = self.router.route(loan_id, data)\n",
    "        t0 = time.monotonic()\n",
    "\n",
    "        if route.path == ExecutionPath.FAST:\n",
    "            result = await self._fast_path(loan_id, data)\n",
    "        else:\n",
    "            # Standard and Full: Fan-Out/Fan-In\n",
    "            result = await self.orch.run_standard_pipeline(loan_id, data)\n",
    "            if route.path == ExecutionPath.FULL:\n",
    "                result['hitl_required'] = True\n",
    "                result['hitl_level'] = 3 if data.get('regulatory_flag') else 1\n",
    "\n",
    "        result.update({\n",
    "            'loan_id': loan_id,\n",
    "            'route': route.path.value,\n",
    "            'complexity_score': route.complexity_score,\n",
    "            'actual_latency_ms': int((time.monotonic()-t0)*1000),\n",
    "            'cost_usd': route.estimated_cost_usd,\n",
    "        })\n",
    "\n",
    "        # Trigger Saga if APPROVE\n",
    "        decision = result.get('decision', result.get('risk', {}).get('decision', 'UNKNOWN'))\n",
    "        if decision == 'APPROVE':\n",
    "            saga = SagaOrchestrator(f'SAGA-{loan_id}')\n",
    "            steps = build_disbursement_saga(loan_id.replace('-', ''), data)\n",
    "            saga_success = saga.run(steps)\n",
    "            result['disbursement'] = 'SUCCESS' if saga_success else 'ROLLED_BACK'\n",
    "        else:\n",
    "            result['disbursement'] = 'N/A'\n",
    "\n",
    "        self.processed.append(result)\n",
    "        return result\n",
    "\n",
    "    def summary(self) -> Dict:\n",
    "        if not self.processed:\n",
    "            return {}\n",
    "        return {\n",
    "            'processed': len(self.processed),\n",
    "            'total_cost_usd': round(sum(r['cost_usd'] for r in self.processed), 4),\n",
    "            'avg_latency_ms': round(statistics.mean(r['actual_latency_ms'] for r in self.processed)),\n",
    "            'paths': {p.value: sum(1 for r in self.processed if r['route'] == p.value) for p in ExecutionPath},\n",
    "        }\n",
    "\n",
    "# ── End-to-End Demo ──\n",
    "async def demo_full_pipeline():\n",
    "    bot = LoanBotV31()\n",
    "    print('=== LoanBot v3.1 Full Integration Demo ===')\n",
    "\n",
    "    for loan_id, data in CUSTOMERS.items():\n",
    "        print(f'\\n{'='*60}')\n",
    "        print(f'Processing: {loan_id} — {data[\"name\"]}')\n",
    "        result = await bot.process(loan_id, data)\n",
    "        decision = result.get('decision', result.get('risk', {}).get('decision', 'UNKNOWN'))\n",
    "        print(f'  Route:        {result[\"route\"]} (complexity={result[\"complexity_score\"]})')\n",
    "        print(f'  Decision:     {decision}')\n",
    "        print(f'  Disbursement: {result.get(\"disbursement\", \"N/A\")}')\n",
    "        print(f'  Latency:      {result[\"actual_latency_ms\"]}ms | Cost: ${result[\"cost_usd\"]:.3f}')\n",
    "        if result.get('hitl_required'):\n",
    "            print(f'  HITL Level:   {result[\"hitl_level\"]}')\n",
    "\n",
    "    print('\\n' + '='*60)\n",
    "    s = bot.summary()\n",
    "    print('📊 Session Summary:')\n",
    "    print(f'  Total processed: {s[\"processed\"]}')\n",
    "    print(f'  Total cost:      ${s[\"total_cost_usd\"]:.4f}')\n",
    "    print(f'  Avg latency:     {s[\"avg_latency_ms\"]}ms')\n",
    "    print(f'  Path breakdown:  {s[\"paths\"]}')\n",
    "\n",
    "asyncio.run(demo_full_pipeline())"
   ]
