    "## Section 2: Fan-Out / Fan-In Orchestrator"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class AgentResult:\n",
    "    agent_name: str\n",
    "    output: Dict\n",
    "    latency_ms: int\n",
    "    success: bool\n",
    "    error: Optional[str] = None\n",
    "\n",
    "class FanOutOrchestrator:\n",
    "    \"\"\"Fan-Out/Fan-In orchestrator với asyncio Semaphore để tránh Thundering Herd.\"\"\"\n",
    "\n",
    "    def __init__(self, max_concurrent: int = 50):\n",
    "        self.semaphore = asyncio.Semaphore(max_concurrent)\n",
    "\n",
    "    async def _call_with_semaphore(self, name: str, coro) -> AgentResult:\n",
    "        async with self.semaphore:\n",
    "            start = time.monotonic()\n",
    "            try:\n",
    "                output = await coro\n",
    "                return AgentResult(name, output, int((time.monotonic()-start)*1000), True)\n",
    "            except Exception as e:\n",
    "                return AgentResult(name, {}, int((time.monotonic()-start)*1000), False, str(e))\n",
    "\n",
    "    async def fan_out(self, tasks: List[Tuple[str, Any]], timeout_s: float = 5.0) -> List[AgentResult]:\n",
    "        \"\"\"tasks = list of (name, coroutine)\"\"\"\n",
    "        coros = [\n",
    "            asyncio.wait_for(self._call_with_semaphore(name, coro), timeout=timeout_s)\n",
    "            for name, coro in tasks\n",
    "        ]\n",
    "        raw = await asyncio.gather(*coros, return_exceptions=True)\n",
    "        results = []\n",
    "        for (name, _), r in zip(tasks, raw):\n",
    "            if isinstance(r, Exception):\n",
    "                results.append(AgentResult(name, {}, 0, False, str(r)))\n",
    "            else:\n",
    "                results.append(r)\n",
    "        return results\n",
    "\n",
    "    def fan_in(self, results: List[AgentResult], strategy: str = 'all_required') -> Dict:\n",
    "        failures = [r for r in results if not r.success]\n",
    "        if strategy == 'all_required' and failures:\n",
    "            failed_names = [r.agent_name for r in failures]\n",
    "            raise RuntimeError(f'Critical agents failed: {failed_names}')\n",
    "        return {r.agent_name: r.output for r in results if r.success}\n",
    "\n",
    "    async def run_standard_pipeline(self, loan_id: str, data: Dict) -> Dict:\n",
    "        \"\"\"Standard Path: Fan-Out 3 agents, fan-in, then sequential RiskAgent.\"\"\"\n",
    "        t0 = time.monotonic()\n",
    "\n",
    "        # Stage 1: Fan-Out\n",
    "        parallel_tasks = [\n",
    "            ('CreditAgent', mock_credit_agent(data)),\n",
    "            ('IncomeAgent', mock_income_agent(data)),\n",
    "            ('FraudAgent',  mock_fraud_agent(data)),\n",
    "        ]\n",
    "        results = await self.fan_out(parallel_tasks)\n",
    "        aggregated = self.fan_in(results)  # all_required\n",
    "\n",
    "        # Stage 2: Sequential RiskAgent\n",
    "        risk = await mock_risk_agent(\n",
    "            data,\n",
    "            aggregated['CreditAgent'],\n",
    "            aggregated['IncomeAgent'],\n",
    "            aggregated['FraudAgent']\n",
    "        )\n",
    "\n",
    "        total_ms = int((time.monotonic()-t0)*1000)\n",
    "        return {\n",
    "            'loan_id': loan_id, 'pattern': 'Fan-Out/Fan-In',\n",
    "            'credit': aggregated['CreditAgent'],\n",
    "            'income': aggregated['IncomeAgent'],\n",
    "            'fraud':  aggregated['FraudAgent'],\n",
    "            'risk':   risk,\n",
    "            'total_latency_ms': total_ms,\n",
    "            'agent_latencies_ms': {r.agent_name: r.latency_ms for r in results}\n",
    "        }\n",
    "\n",
    "# ── Demo ──\n",
    "async def demo_fan_out():\n",
    "    orch = FanOutOrchestrator(max_concurrent=10)\n",
    "    print('=== Fan-Out / Fan-In Demo ===')\n",
    "    for loan_id, data in CUSTOMERS.items():\n",
    "        result = await orch.run_standard_pipeline(loan_id, data)\n",
    "        cr = result['credit']\n",
    "        fr = result['fraud']\n",
    "        risk = result['risk']\n",
    "        print(f\"\\n{loan_id} — {data['name']}\")\n",
    "        print(f\"  Credit:  score={cr['credit_score']} grade={cr['credit_grade']} DTI={cr['dti']}\")\n",
    "        print(f\"  Fraud:   probability={fr['fraud_probability']} tier={fr['fraud_tier']}\")\n",
    "        print(f\"  Risk:    score={risk['risk_score']} → {risk['decision']}\")\n",
    "        print(f\"  Latency: {result['total_latency_ms']}ms total | agents={result['agent_latencies_ms']}\")\n",
    "\n",
    "asyncio.run(demo_fan_out())"
   ]
