    "## Section 4: Saga Pattern — Distributed Transactions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from enum import Enum\n",
    "\n",
    "class SagaStatus(Enum):\n",
    "    RUNNING    = 'RUNNING'\n",
    "    COMPLETED  = 'COMPLETED'\n",
    "    ROLLING_BACK = 'ROLLING_BACK'\n",
    "    ROLLED_BACK  = 'ROLLED_BACK'\n",
    "\n",
    "@dataclass\n",
    "class SagaStep:\n",
    "    name: str\n",
    "    action: Callable[[Dict], Dict]      # forward action\n",
    "    compensate: Callable[[Dict], None]  # compensating action\n",
    "    critical: bool = True               # if False, failure → log only (no rollback)\n",
    "\n",
    "@dataclass\n",
    "class SagaEvent:\n",
    "    step: str\n",
    "    event_type: str  # 'STARTED', 'SUCCEEDED', 'FAILED', 'COMPENSATED'\n",
    "    details: Dict\n",
    "\n",
    "class SagaOrchestrator:\n",
    "    \"\"\"Orchestration Saga: central coordinator với rollback capability.\"\"\"\n",
    "\n",
    "    def __init__(self, saga_id: str):\n",
    "        self.saga_id = saga_id\n",
    "        self.status  = SagaStatus.RUNNING\n",
    "        self.log: List[SagaEvent] = []\n",
    "        self.completed_steps: List[SagaStep] = []\n",
    "        self.context: Dict = {}\n",
    "\n",
    "    def _record(self, step: str, event_type: str, details: Dict):\n",
    "        self.log.append(SagaEvent(step, event_type, details))\n",
    "\n",
    "    def _rollback(self):\n",
    "        self.status = SagaStatus.ROLLING_BACK\n",
    "        print(f'  ↩ Rolling back {len(self.completed_steps)} steps...')\n",
    "        for step in reversed(self.completed_steps):\n",
    "            try:\n",
    "                step.compensate(self.context)\n",
    "                self._record(step.name, 'COMPENSATED', {'context': self.context})\n",
    "                print(f'    ✓ Compensated: {step.name}')\n",
    "            except Exception as e:\n",
    "                self._record(step.name, 'COMPENSATION_FAILED', {'error': str(e)})\n",
    "                print(f'    ✗ Compensation failed: {step.name} — {e}')\n",
    "        self.status = SagaStatus.ROLLED_BACK\n",
    "\n",
    "    def run(self, steps: List[SagaStep]) -> bool:\n",
    "        print(f'\\n🔄 Saga {self.saga_id} starting ({len(steps)} steps)')\n",
    "        for step in steps:\n",
    "            self._record(step.name, 'STARTED', {})\n",
    "            print(f'  → {step.name}...')\n",
    "            try:\n",
    "                result = step.action(self.context)\n",
    "                self.context.update(result or {})\n",
    "                self._record(step.name, 'SUCCEEDED', result or {})\n",
    "                if step.critical:\n",
    "                    self.completed_steps.append(step)\n",
    "                print(f'  ✅ {step.name}: {result}')\n",
    "            except Exception as e:\n",
    "                self._record(step.name, 'FAILED', {'error': str(e)})\n",
    "                print(f'  ❌ {step.name} FAILED: {e}')\n",
    "                if step.critical:\n",
    "                    self._rollback()\n",
    "                    return False\n",
    "                else:\n",
    "                    print(f'  ⚠️ Non-critical failure — continuing saga')\n",
    "        self.status = SagaStatus.COMPLETED\n",
    "        print(f'  🏁 Saga {self.saga_id} COMPLETED')\n",
    "        return True\n",
    "\n",
    "    def print_audit_trail(self):\n",
    "        print(f'\\n📋 Audit Trail — Saga {self.saga_id}')\n",
    "        for e in self.log:\n",
    "            icon = {'STARTED':'▶','SUCCEEDED':'✓','FAILED':'✗','COMPENSATED':'↩','COMPENSATION_FAILED':'🚨'}.get(e.event_type,'?')\n",
    "            print(f'  {icon} [{e.event_type:20s}] {e.step}')\n",
    "\n",
    "# ─── Define LoanBot Disbursement Saga Steps ───\n",
    "def build_disbursement_saga(loan_id: str, customer: Dict, inject_failure_at: Optional[str] = None):\n",
    "    state = {'contracts': set(), 'reserved_funds': False, 'loan_id': loan_id}\n",
    "\n",
    "    def create_contract(ctx):\n",
    "        if inject_failure_at == 'CREATE_CONTRACT':\n",
    "            raise RuntimeError('Contract service timeout')\n",
    "        contract_id = f'LN-{loan_id}'\n",
    "        state['contracts'].add(contract_id)\n",
    "        return {'contract_id': contract_id, 'customer': customer['name']}\n",
    "\n",
    "    def delete_contract(ctx):\n",
    "        state['contracts'].discard(ctx.get('contract_id', ''))\n",
    "\n",
    "    def reserve_funds(ctx):\n",
    "        if inject_failure_at == 'RESERVE_FUNDS':\n",
    "            raise RuntimeError('Treasury service unavailable')\n",
    "        state['reserved_funds'] = True\n",
    "        return {'reserved_amount_vnd': customer['loan_amount_vnd']}\n",
    "\n",
    "    def release_funds(ctx):\n",
    "        state['reserved_funds'] = False\n",
    "\n",
    "    def disburse_loan(ctx):\n",
    "        if inject_failure_at == 'DISBURSE_LOAN':\n",
    "            raise RuntimeError('Core banking timeout — disbursement failed')\n",
    "        state['reserved_funds'] = False\n",
    "        return {'transfer_ref': f'TXN-{loan_id}', 'status': 'DISBURSED'}\n",
    "\n",
    "    def reverse_transfer(ctx):\n",
    "        pass  # would call reversal API\n",
    "\n",
    "    def update_crm(ctx):\n",
    "        if inject_failure_at == 'UPDATE_CRM':\n",
    "            raise RuntimeError('Salesforce API rate limit')\n",
    "        return {'crm_status': 'CLOSED_WON', 'opportunity_id': f'OPP-{loan_id}'}\n",
    "\n",
    "    def revert_crm(ctx):\n",
    "        pass  # reset opportunity to previous state\n",
    "\n",
    "    def notify_customer(ctx):\n",
    "        if inject_failure_at == 'NOTIFY_CUSTOMER':\n",
    "            raise RuntimeError('SMS gateway: customer unreachable')\n",
    "        return {'notification': 'SMS_SENT'}\n",
    "\n",
    "    return [\n",
    "        SagaStep('CREATE_CONTRACT', create_contract, delete_contract,  critical=True),\n",
    "        SagaStep('RESERVE_FUNDS',   reserve_funds,   release_funds,    critical=True),\n",
    "        SagaStep('DISBURSE_LOAN',   disburse_loan,   reverse_transfer, critical=True),\n",
    "        SagaStep('UPDATE_CRM',      update_crm,      revert_crm,       critical=True),\n",
    "        SagaStep('NOTIFY_CUSTOMER', notify_customer, lambda ctx: None, critical=False),  # non-critical\n",
    "    ]\n",
    "\n",
    "# ── Demo 1: Happy Path ──\n",
    "print('=== Saga Demo 1: Happy Path (FC-2024-001) ===')\n",
    "saga1 = SagaOrchestrator('SAGA-FC-2024-001')\n",
    "steps1 = build_disbursement_saga('FC2024001', CUSTOMERS['FC-2024-001'])\n",
    "saga1.run(steps1)\n",
    "saga1.print_audit_trail()\n",
    "\n",
    "# ── Demo 2: DISBURSE_LOAN fails → rollback ──\n",
    "print('\\n=== Saga Demo 2: DISBURSE_LOAN Failure → Rollback ===')\n",
    "saga2 = SagaOrchestrator('SAGA-FC-2024-004-FAIL')\n",
    "steps2 = build_disbursement_saga('FC2024004', CUSTOMERS['FC-2024-004'], inject_failure_at='DISBURSE_LOAN')\n",
    "saga2.run(steps2)\n",
    "saga2.print_audit_trail()\n",
    "\n",
    "# ── Demo 3: NOTIFY_CUSTOMER fails (non-critical) → continue ──\n",
    "print('\\n=== Saga Demo 3: NOTIFY_CUSTOMER Failure (non-critical) ===')\n",
    "saga3 = SagaOrchestrator('SAGA-FC-2024-002-NOTIFY')\n",
    "steps3 = build_disbursement_saga('FC2024002', CUSTOMERS['FC-2024-002'], inject_failure_at='NOTIFY_CUSTOMER')\n",
    "saga3.run(steps3)\n",
    "saga3.print_audit_trail()"
   ]
