   "source": [
    "import math\n",
    "\n",
    "def generate_synthetic_portfolio(n: int = 500, seed: int = 42) -> List[Dict]:\n",
    "    \"\"\"Generate synthetic loan portfolio for Map-Reduce demo.\"\"\"\n",
    "    rng = random.Random(seed)\n",
    "    apps = []\n",
    "    for i in range(n):\n",
    "        score = max(300, min(850, int(rng.gauss(620, 100))))\n",
    "        income = max(5_000_000, int(rng.gauss(18_000_000, 8_000_000)))\n",
    "        amount = max(30_000_000, min(2_000_000_000, int(rng.gauss(250_000_000, 150_000_000))))\n",
    "        fraud_p = max(0.0, min(1.0, rng.gauss(0.15, 0.15)))\n",
    "        apps.append({\n",
    "            'loan_id': f'BATCH-{i+1:04d}',\n",
    "            'credit_score': score,\n",
    "            'monthly_income_vnd': income,\n",
    "            'loan_amount_vnd': amount,\n",
    "            'fraud_probability': round(fraud_p, 3),\n",
    "            'employment_months': rng.randint(3, 120),\n",
    "            'regulatory_flag': rng.random() < 0.03,\n",
    "        })\n",
    "    return apps\n",
    "\n",
    "def map_evaluate(app: Dict) -> Dict:\n",
    "    \"\"\"Map function: evaluate a single loan application (synchronous mock).\"\"\"\n",
    "    score = app['credit_score']\n",
    "    fp = app['fraud_probability']\n",
    "    risk_score = round((1 - score/850) * 0.5 + fp * 0.5, 3)\n",
    "    hitl = fp > 0.30 or app['loan_amount_vnd'] > 500_000_000 or (560 <= score <= 680) or app['regulatory_flag']\n",
    "\n",
    "    if fp > 0.70 or score < 450:\n",
    "        decision = 'REJECT'\n",
    "    elif risk_score < 0.35 and app['monthly_income_vnd'] >= 8_000_000:\n",
    "        decision = 'APPROVE'\n",
    "    else:\n",
    "        decision = 'REJECT'\n",
    "\n",
    "    return {**app, 'risk_score': risk_score, 'decision': decision, 'hitl_required': hitl}\n",
    "\n",
    "class PortfolioReducer:\n",
    "    \"\"\"Reducer: aggregate 500 results into portfolio statistics.\"\"\"\n",
    "\n",
    "    def reduce(self, results: List[Dict]) -> Dict:\n",
    "        total = len(results)\n",
    "        approved = [r for r in results if r['decision'] == 'APPROVE']\n",
    "        rejected = [r for r in results if r['decision'] == 'REJECT']\n",
    "        hitl     = [r for r in results if r.get('hitl_required')]\n",
    "\n",
    "        approved_value = sum(r['loan_amount_vnd'] for r in approved)\n",
    "        risk_scores    = sorted([r['risk_score'] for r in results])\n",
    "        p95_idx        = int(len(risk_scores) * 0.95)\n",
    "\n",
    "        buckets = {'high_720+': 0, 'medium_560-719': 0, 'low_below560': 0}\n",
    "        for r in results:\n",
    "            s = r['credit_score']\n",
    "            if   s >= 720: buckets['high_720+'] += 1\n",
    "            elif s >= 560: buckets['medium_560-719'] += 1\n",
    "            else:          buckets['low_below560'] += 1\n",
    "\n",
    "        return {\n",
    "            'total':               total,\n",
    "            'approved_count':      len(approved),\n",
    "            'rejected_count':      len(rejected),\n",
    "            'approve_rate':        round(len(approved)/total, 3),\n",
    "            'total_approved_vnd':  approved_value,\n",
    "            'hitl_count':          len(hitl),\n",
    "            'hitl_rate':           round(len(hitl)/total, 3),\n",
    "            'avg_risk_score':      round(statistics.mean(risk_scores), 3),\n",
    "            'risk_p95':            round(risk_scores[p95_idx], 3),\n",
    "            'credit_buckets':      buckets,\n",
    "        }\n",
    "\n",
    "class MapReducePipeline:\n",
    "    \"\"\"Map-Reduce orchestrator: partition → map (parallel) → reduce.\"\"\"\n",
    "\n",
    "    def __init__(self, batch_size: int = 50):\n",
    "        self.batch_size = batch_size\n",
    "        self.reducer = PortfolioReducer()\n",
    "\n",
    "    def partition(self, apps: List[Dict]) -> List[List[Dict]]:\n",
    "        return [apps[i:i+self.batch_size] for i in range(0, len(apps), self.batch_size)]\n",
    "\n",
    "    def map_batch(self, batch: List[Dict]) -> List[Dict]:\n",
    "        return [map_evaluate(app) for app in batch]\n",
    "\n",
    "    def run(self, apps: List[Dict]) -> Dict:\n",
    "        t0 = time.monotonic()\n",
    "        batches = self.partition(apps)\n",
    "\n",
    "        # Map phase (in production: parallel workers)\n",
    "        all_results = []\n",
    "        for batch in batches:\n",
    "            all_results.extend(self.map_batch(batch))\n",
    "\n",
    "        # Reduce phase\n",
    "        report = self.reducer.reduce(all_results)\n",
    "        report['processing_time_s'] = round(time.monotonic()-t0, 3)\n",
    "        report['batch_count'] = len(batches)\n",
    "        return report\n",
    "\n",
    "# ── Demo ──\n",
    "print('=== Map-Reduce Pipeline Demo ===')\n",
    "portfolio = generate_synthetic_portfolio(500)\n",
    "pipeline  = MapReducePipeline(batch_size=50)\n",
    "report    = pipeline.run(portfolio)\n",
    "\n",
    "print(f\"\\n📊 Portfolio Report ({report['total']} applications)\")\n",
    "print(f\"  ✅ Approved:    {report['approved_count']} ({report['approve_rate']*100:.1f}%)\")\n",
    "print(f\"  ❌ Rejected:    {report['rejected_count']} ({(1-report['approve_rate'])*100:.1f}%)\")\n",
    "print(f\"  👤 HITL:        {report['hitl_count']} ({report['hitl_rate']*100:.1f}%)\")\n",
    "print(f\"  💰 Total Value: {report['total_approved_vnd']/1e9:.1f} tỷ VNĐ\")\n",
    "print(f\"  📈 Avg Risk:    {report['avg_risk_score']} | P95 Risk: {report['risk_p95']}\")\n",
    "print(f\"  📦 Buckets:     {report['credit_buckets']}\")\n",
    "print(f\"  ⏱  Processed:   {report['processing_time_s']}s in {report['batch_count']} batches\")"
   ]
  },
