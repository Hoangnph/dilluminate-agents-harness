   "source": [
    "## Section 5: Dynamic Router"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from dataclasses import dataclass\n",
    "\n",
    "class ExecutionPath(Enum):\n",
    "    FAST     = 'FAST'\      # CreditAgent → AutoApprove (~1.5s)\n",
    "    STANDARD = 'STANDARD'  # Fan-Out(3) + Risk + Compliance (~3.7s)\n",
    "    FULL     = 'FULL'       # All 8 agents + HITL (~6.8s)\n",
    "\n",
    "@dataclass\n",
    "class RoutingDecision:\n",
    "    path: ExecutionPath\n",
    "    complexity_score: float\n",
    "    reasons: List[str]\n",
    "    estimated_cost_usd: float\n",
    "    estimated_latency_s: float\n",
    "\n",
    "class DynamicRouter:\n",
    "    \"\"\"Runtime path selector based on loan complexity.\"\"\"\n",
    "\n",
    "    # Thresholds\n",
    "    FAST_SCORE_MIN       = 700\n",
    "    FAST_AMOUNT_MAX      = 300_000_000\n",
    "    FAST_FRAUD_MAX       = 0.10\n",
    "    FULL_BORDERLINE_MIN  = 560\n",
    "    FULL_BORDERLINE_MAX  = 680\n",
    "    FULL_FRAUD_HIGH      = 0.25\n",
    "    FULL_AMOUNT_HIGH     = 500_000_000\n",
    "\n",
    "    # Cost per path (USD)\n",
    "    COST = {ExecutionPath.FAST: 0.002, ExecutionPath.STANDARD: 0.006, ExecutionPath.FULL: 0.012}\n",
    "    LATENCY = {ExecutionPath.FAST: 1.5, ExecutionPath.STANDARD: 3.7, ExecutionPath.FULL: 6.8}\n",
    "\n",
    "    def complexity_score(self, data: Dict) -> Tuple[float, List[str]]:\n",
    "        \"\"\"0.0 = simple, 1.0 = highly complex. Returns (score, reasons).\"\"\"\n",
    "        score = 0.0\n",
    "        reasons = []\n",
    "\n",
    "        # Credit score contribution\n",
    "        cs = data['credit_score']\n",
    "        if cs < 500:\n",
    "            score += 0.4; reasons.append(f'very low credit score ({cs})')\n",
    "        elif cs < 620:\n",
    "            score += 0.25; reasons.append(f'low credit score ({cs})')\n",
    "        elif self.FULL_BORDERLINE_MIN <= cs <= self.FULL_BORDERLINE_MAX:\n",
    "            score += 0.20; reasons.append(f'borderline credit score ({cs})')\n",
    "\n",
    "        # Loan amount\n",
    "        amount = data['loan_amount_vnd']\n",
    "        if amount > self.FULL_AMOUNT_HIGH:\n",
    "            score += 0.25; reasons.append(f'high amount ({amount/1e6:.0f}M VNĐ)')\n",
    "        elif amount > self.FAST_AMOUNT_MAX:\n",
    "            score += 0.10; reasons.append(f'medium amount ({amount/1e6:.0f}M VNĐ)')\n",
    "\n",
    "        # Fraud signal\n",
    "        fp = data['fraud_probability']\n",
    "        if fp > 0.50:\n",
    "            score += 0.35; reasons.append(f'high fraud probability ({fp:.2f})')\n",
    "        elif fp > self.FULL_FRAUD_HIGH:\n",
    "            score += 0.20; reasons.append(f'elevated fraud signal ({fp:.2f})')\n",
    "\n",
    "        # Regulatory flag\n",
    "        if data.get('regulatory_flag'):\n",
    "            score += 0.20; reasons.append('regulatory flag set')\n",
    "\n",
    "        return round(min(score, 1.0), 3), reasons\n",
    "\n",
    "    def route(self, loan_id: str, data: Dict) -> RoutingDecision:\n",
    "        cs_val, reasons = self.complexity_score(data)\n",
    "\n",
    "        # Fast path: very simple case\n",
    "        if (data['credit_score'] >= self.FAST_SCORE_MIN and\n",
    "            data['loan_amount_vnd'] <= self.FAST_AMOUNT_MAX and\n",
    "            data['fraud_probability'] <= self.FAST_FRAUD_MAX and\n",
    "            not data.get('regulatory_flag')):\n",
    "            path = ExecutionPath.FAST\n",
    "        # Full path: complex case\n",
    "        elif cs_val >= 0.40 or data.get('regulatory_flag') or data['fraud_probability'] > self.FULL_FRAUD_HIGH:\n",
    "            path = ExecutionPath.FULL\n",
    "        else:\n",
    "            path = ExecutionPath.STANDARD\n",
    "\n",
    "        return RoutingDecision(\n",
    "            path=path, complexity_score=cs_val, reasons=reasons,\n",
    "            estimated_cost_usd=self.COST[path],\n",
    "            estimated_latency_s=self.LATENCY[path]\n",
    "        )\n",
    "\n",
    "# ── Demo ──\n",
    "router = DynamicRouter()\n",
    "print('=== Dynamic Router Demo ===')\n",
    "path_counts = {p: 0 for p in ExecutionPath}\n",
    "\n",
    "for loan_id, data in CUSTOMERS.items():\n",
    "    decision = router.route(loan_id, data)\n",
    "    path_counts[decision.path] += 1\n",
    "    print(f\"\\n{loan_id} — {data['name']}\")\n",
    "    print(f\"  Path:       {decision.path.value}\")\n",
    "    print(f\"  Complexity: {decision.complexity_score}\")\n",
    "    print(f\"  Reasons:    {decision.reasons}\")\n",
    "    print(f\"  Cost:       ${decision.estimated_cost_usd:.3f} | Latency: {decision.estimated_latency_s}s\")\n",
    "\n",
    "print('\\n📊 Path Distribution:')\n",
    "for path, count in path_counts.items():\n",
    "    print(f'  {path.value:10s}: {count} ({count/len(CUSTOMERS)*100:.0f}%)')\n",
    "\n",
    "# Simulate cost for 50.000/month\n",
    "dist = {'FAST': 0.25, 'STANDARD': 0.62, 'FULL': 0.13}\n",
    "total_apps = 50_000\n",
    "costs = {p: dist[p.value if hasattr(p,'value') else p] * total_apps * c for p, c in router.COST.items()}\n",
    "total_cost = sum(costs.values())\n",
    "uniform_cost = total_apps * 0.006\n",
    "print(f'\\n💰 Monthly Cost Estimate (50.000 apps):')\n",
    "for path, c in costs.items():\n",
    "    print(f'  {path.value:10s}: ${c:.0f}')\n",
    "print(f'  Total Dynamic:  ${total_cost:.0f}')\n",
    "print(f'  Uniform Std:    ${uniform_cost:.0f}')\n",
    "print(f'  Savings:        ${uniform_cost-total_cost:.0f} ({(uniform_cost-total_cost)/uniform_cost*100:.0f}%)')"
   ]
  },
